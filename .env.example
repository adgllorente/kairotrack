# Required
AUTH_USER=admin
AUTH_PASSWORD=changeme
SESSION_SECRET=replace_with_32_byte_random_hex

# Optional
PORT=3000
TZ=Europe/Madrid
NODE_ENV=production

# DB_PATH only needed if you want to override.
# In Docker the image sets DB_PATH=/data/kairotrack.db automatically.
# In local dev it defaults to ./data/kairotrack.db
# DB_PATH=/data/kairotrack.db
